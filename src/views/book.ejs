<%- include('partials/header') %>

  <!-- ===== SIDEBAR: Book Navigation ===== -->
  <aside class="sidebar">
    <a href="/" class="sidebar-back">&larr; All Resources</a>

    <div class="sidebar-book-info">
      <div class="sidebar-book-cover<% if (!book.coverPath) { %> cover-green<% } %>"><% if (book.coverPath) { %><img src="/cover/<%= book.coverPath %>" alt="<%= book.title %>" class="sidebar-book-cover-img"><% } %></div>
      <div class="sidebar-book-title"><%= book.title %></div>
      <% if (book.subtitle) { %>
        <div class="sidebar-book-subtitle"><%= book.subtitle %></div>
      <% } %>
    </div>

    <div class="sidebar-sessions-title">Sessions</div>
    <ul class="nav-session-list">
      <% book.sessions.forEach(function(s, i) { %>
        <li>
          <a href="<%= content.sessionUrl(series, subseries, book, s) %>" class="nav-session-item">
            <span class="session-num"><%= i + 1 %></span>
            <span class="nav-session-name"><%= s.displayName %></span>
          </a>
        </li>
      <% }); %>
    </ul>
  </aside>

  <!-- ===== MAIN CONTENT ===== -->
  <main class="main">
    <div class="book-detail-top">
      <div class="book-detail-header">
        <div class="book-detail-cover<% if (!book.coverPath) { %> cover-green<% } %>"><% if (book.coverPath) { %><img src="/cover/<%= book.coverPath %>" alt="<%= book.title %>" class="book-detail-cover-img"><% } else { %><%= book.title %><% } %></div>
        <div class="book-detail-info">
          <div class="breadcrumb">
            <a href="/">Resources</a> <span>&rsaquo;</span>
            <a href="/#series-<%= series.slug %>"><%= series.title %></a>
            <% if (subseries) { %>
              <span>&rsaquo;</span>
              <a href="/#series-<%= series.slug %>"><%= subseries.title %></a>
            <% } %>
          </div>

          <% if (book.banner === 'Preview') { %>
            <div class="banner-bar banner-preview">Preview</div>
          <% } else if (book.banner === 'Pre-Release') { %>
            <div class="banner-bar banner-prerelease">Pre-Release</div>
          <% } %>

          <h1 class="page-title"><%= book.title %></h1>
          <% if (book.subtitle) { %>
            <p class="book-detail-subtitle"><%= book.subtitle %></p>
          <% } %>

          <div class="book-detail-meta">
            <span><%= book.sessions.length %> <%= book.sessions.length === 1 ? 'session' : 'sessions' %></span>
            <span class="meta-sep">&middot;</span>
            <span><%= series.title %></span>
            <% if (subseries) { %>
              <span class="meta-sep">&middot;</span>
              <span><%= subseries.title %></span>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="book-sessions-area">
      <div class="sessions-heading-label">Sessions</div>
      <ul class="session-list">
        <% book.sessions.forEach(function(s, i) { %>
          <li>
            <a href="<%= content.sessionUrl(series, subseries, book, s) %>">
              <span class="session-num"><%= i + 1 %></span>
              <span class="session-name"><%= s.displayName %></span>
              <span class="session-arrow">&rsaquo;</span>
            </a>
          </li>
        <% }); %>
      </ul>
    </div>
  </main>

<%- include('partials/footer') %>
