<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Noble Collective Resources</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=DM+Serif+Display&family=Lora:ital,wght@0,400;0,500;1,400;1,500&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/style.css?v=40">
</head>
<body>

<header class="site-header">
  <div class="header-inner">
    <!-- Hamburger (mobile only) -->
    <div class="menu-drawer-container">
      <button class="hamburger-btn" aria-label="Menu" aria-expanded="false" data-drawer-toggle>
        <svg class="icon-hamburger" viewBox="0 0 18 16" fill="none"><path fill="currentColor" d="M1 .5a.5.5 0 1 0 0 1h15.71a.5.5 0 0 0 0-1zM.5 8a.5.5 0 0 1 .5-.5h15.71a.5.5 0 0 1 0 1H1A.5.5 0 0 1 .5 8m0 7a.5.5 0 0 1 .5-.5h15.71a.5.5 0 0 1 0 1H1a.5.5 0 0 1-.5-.5"/></svg>
        <svg class="icon-close" viewBox="0 0 18 17" fill="none"><path fill="currentColor" d="M.865 15.978a.5.5 0 0 0 .707.707l7.433-7.431 7.579 7.282a.501.501 0 0 0 .846-.37.5.5 0 0 0-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 1 0-.707-.708L8.991 7.853 1.413.573a.5.5 0 1 0-.693.72l7.563 7.268z"/></svg>
      </button>
    </div>

    <a href="https://noblecollective.org" class="logo">
      <img src="https://noblecollective.org/cdn/shop/files/imgi_1_white-icon-2_1.png?v=1762221761&width=600" alt="Noble Collective" class="logo-img">
    </a>
    <nav class="desktop-nav">
      <div class="nav-dropdown">
        <button class="nav-dropdown-toggle" type="button"><span>About</span> <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="nav-dropdown-menu">
          <a href="https://noblecollective.org/pages/mission-vision">Mission & Vision</a>
          <a href="https://noblecollective.org/pages/board">Board</a>
          <a href="https://noblecollective.org/pages/contact-us">Contact Us</a>
        </div>
      </div>
      <a href="https://noblecollective.org/pages/cohorts"><span>Cohorts</span></a>
      <a href="https://noblecollective.org/pages/conferences"><span>Conferences</span></a>
      <a href="https://noblecollective.org/pages/store"><span>Store</span></a>
      <a href="/" class="active"><span>Resources</span></a>
    </nav>
    <div class="header-icons">
      <a href="https://give.tithe.ly/?formId=de450668-6864-11ee-90fc-1260ab546d11" class="give-btn" target="_blank" rel="noopener"><span class="noble-text">GIVE</span> <svg class="arrow-icon" width="15" viewBox="0 0 20 20" fill="none"><path d="M7 5l6 5-6 5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
    </div>
  </div>
  <!-- Mobile drawer (inside header for positioning) -->
  <div class="menu-drawer-overlay" data-drawer-overlay></div>
  <div class="menu-drawer" data-drawer>
    <div class="menu-drawer__inner">
      <nav class="menu-drawer__nav">
        <ul class="menu-drawer__menu">
          <li>
            <button class="menu-drawer__menu-item menu-drawer__submenu-toggle" data-submenu="about">
              About
              <svg class="menu-drawer__arrow" viewBox="0 0 14 10" fill="none"><path fill="currentColor" fill-rule="evenodd" d="M8.537.808a.5.5 0 0 1 .817-.162l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 1 1-.708-.708L11.793 5.5H1a.5.5 0 0 1 0-1h10.793L8.646 1.354a.5.5 0 0 1-.109-.546" clip-rule="evenodd"/></svg>
            </button>
            <div class="menu-drawer__submenu" data-submenu-panel="about">
              <button class="menu-drawer__back-btn" data-submenu-back>
                <svg class="menu-drawer__back-arrow" viewBox="0 0 14 10" fill="none"><path fill="currentColor" fill-rule="evenodd" d="M8.537.808a.5.5 0 0 1 .817-.162l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 1 1-.708-.708L11.793 5.5H1a.5.5 0 0 1 0-1h10.793L8.646 1.354a.5.5 0 0 1-.109-.546" clip-rule="evenodd"/></svg>
                About
              </button>
              <ul class="menu-drawer__menu">
                <li><a href="https://noblecollective.org/pages/mission-vision" class="menu-drawer__menu-item">Mission & Vision</a></li>
                <li><a href="https://noblecollective.org/pages/board" class="menu-drawer__menu-item">Board</a></li>
                <li><a href="https://noblecollective.org/pages/contact-us" class="menu-drawer__menu-item">Contact Us</a></li>
              </ul>
            </div>
          </li>
          <li><a href="https://noblecollective.org/pages/cohorts" class="menu-drawer__menu-item">Cohorts</a></li>
          <li><a href="https://noblecollective.org/pages/conferences" class="menu-drawer__menu-item">Conferences</a></li>
          <li><a href="https://noblecollective.org/pages/store" class="menu-drawer__menu-item">Store</a></li>
          <li><a href="/" class="menu-drawer__menu-item menu-drawer__menu-item--active">Resources</a></li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<div class="layout">
