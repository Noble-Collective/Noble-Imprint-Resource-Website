<%- include('partials/header') %>

  <!-- ===== SIDEBAR: Session Navigation ===== -->
  <aside class="sidebar">
    <a href="<%= content.bookUrl(series, subseries, book) %>" class="sidebar-back">&larr; <%= book.title %></a>

    <ul class="nav-session-list">
      <% book.sessions.forEach(function(s, i) { %>
        <li>
          <a href="<%= content.sessionUrl(series, subseries, book, s) %>" class="nav-session-item<%= s.slug === session.slug ? ' active' : '' %>">
            <span class="session-num"><%= i + 1 %></span>
            <span class="nav-session-name"><%= s.displayName %></span>
          </a>
          <% if (s.slug === session.slug && h2s && h2s.length > 0) { %>
            <ul class="nav-h2-list">
              <% h2s.forEach(function(h) { %>
                <li>
                  <a href="#<%= h.slug %>" class="nav-h2-item"><%= h.text %></a>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </li>
      <% }); %>
    </ul>
  </aside>

  <!-- ===== MOBILE TOC BAR ===== -->
  <div class="mobile-toc-bar" data-mobile-toc>
    <button class="mobile-toc-toggle" data-mobile-toc-toggle>
      <span class="mobile-toc-label"><%= session.title || session.displayName %></span>
      <svg class="mobile-toc-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="mobile-toc-panel" data-mobile-toc-panel>
      <% if (h2s && h2s.length > 0) { %>
        <ul class="mobile-toc-list">
          <% h2s.forEach(function(h) { %>
            <li><a href="#<%= h.slug %>" class="mobile-toc-link"><%= h.text %></a></li>
          <% }); %>
        </ul>
      <% } %>
      <div class="mobile-toc-nav">
        <% if (prevSession) { %>
          <a href="<%= content.sessionUrl(series, subseries, book, prevSession) %>" class="mobile-toc-nav-link">&larr; <%= prevSession.displayName %></a>
        <% } %>
        <% if (nextSession) { %>
          <a href="<%= content.sessionUrl(series, subseries, book, nextSession) %>" class="mobile-toc-nav-link mobile-toc-nav-next"><%= nextSession.displayName %> &rarr;</a>
        <% } %>
      </div>
    </div>
  </div>

  <!-- ===== MAIN CONTENT ===== -->
  <main class="main">
    <div class="reading-top">
      <div class="breadcrumb">
        <a href="/">Resources</a> <span>&rsaquo;</span>
        <a href="/#series-<%= series.slug %>"><%= series.title %></a>
        <% if (subseries) { %>
          <span>&rsaquo;</span>
          <a href="/#series-<%= series.slug %>"><%= subseries.title %></a>
        <% } %>
        <span>&rsaquo;</span>
        <a href="<%= content.bookUrl(series, subseries, book) %>"><%= book.title %></a>
        <span>&rsaquo;</span>
        <%= session.title || session.displayName %>
      </div>
    </div>

    <div class="reading-content">
      <div class="session-content">
        <%- sessionHtml %>
      </div>

      <div class="session-nav">
        <% if (prevSession) { %>
          <a href="<%= content.sessionUrl(series, subseries, book, prevSession) %>" class="session-nav-link session-nav-prev">
            <span class="session-nav-dir">&larr; Previous</span>
            <span class="session-nav-name"><%= prevSession.displayName %></span>
          </a>
        <% } else { %>
          <div class="session-nav-link session-nav-placeholder"></div>
        <% } %>
        <% if (nextSession) { %>
          <a href="<%= content.sessionUrl(series, subseries, book, nextSession) %>" class="session-nav-link session-nav-next">
            <span class="session-nav-dir">Next &rarr;</span>
            <span class="session-nav-name"><%= nextSession.displayName %></span>
          </a>
        <% } else { %>
          <div class="session-nav-link session-nav-placeholder"></div>
        <% } %>
      </div>
    </div>
  </main>

<%- include('partials/footer') %>
