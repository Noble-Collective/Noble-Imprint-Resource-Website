<%- include('partials/header') %>

  <!-- ===== SIDEBAR: Session Navigation ===== -->
  <aside class="sidebar">
    <a href="<%= content.bookUrl(series, subseries, book) %>" class="sidebar-back">&larr; <%= book.title %></a>

    <ul class="nav-session-list">
      <% book.sessions.forEach(function(s, i) { %>
        <li>
          <a href="<%= content.sessionUrl(series, subseries, book, s) %>" class="nav-session-item<%= s.slug === session.slug ? ' active' : '' %>">
            <span class="session-num"><%= i + 1 %></span>
            <span class="nav-session-name"><%= s.displayName %></span>
          </a>
          <% if (s.slug === session.slug && h2s && h2s.length > 0) { %>
            <ul class="nav-h2-list">
              <% h2s.forEach(function(h) { %>
                <li>
                  <a href="#<%= h.slug %>" class="nav-h2-item"><%= h.text %></a>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </li>
      <% }); %>
    </ul>
    <%- include('partials/sidebar-auth') %>
  </aside>

  <!-- ===== MOBILE TOC BAR ===== -->
  <div class="mobile-toc-bar" data-mobile-toc>
    <button class="mobile-toc-toggle" data-mobile-toc-toggle>
      <span class="mobile-toc-label"><%= session.title || session.displayName %></span>
      <svg class="mobile-toc-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="mobile-toc-panel" data-mobile-toc-panel>
      <% if (h2s && h2s.length > 0) { %>
        <ul class="mobile-toc-list">
          <% h2s.forEach(function(h) { %>
            <li><a href="#<%= h.slug %>" class="mobile-toc-link"><%= h.text %></a></li>
          <% }); %>
        </ul>
      <% } %>
      <div class="mobile-toc-nav">
        <% if (prevSession) { %>
          <a href="<%= content.sessionUrl(series, subseries, book, prevSession) %>" class="mobile-toc-nav-link">&larr; <%= prevSession.displayName %></a>
        <% } %>
        <% if (nextSession) { %>
          <a href="<%= content.sessionUrl(series, subseries, book, nextSession) %>" class="mobile-toc-nav-link mobile-toc-nav-next"><%= nextSession.displayName %> &rarr;</a>
        <% } %>
      </div>
    </div>
  </div>

  <!-- ===== MAIN CONTENT ===== -->
  <main class="main">
    <div class="reading-top">
      <div class="breadcrumb">
        <a href="/">Resources</a> <span>&rsaquo;</span>
        <a href="/#series-<%= series.slug %>"><%= series.title %></a>
        <% if (subseries) { %>
          <span>&rsaquo;</span>
          <a href="/#series-<%= series.slug %>"><%= subseries.title %></a>
        <% } %>
        <span>&rsaquo;</span>
        <a href="<%= content.bookUrl(series, subseries, book) %>"><%= book.title %></a>
        <span>&rsaquo;</span>
        <%= session.title || session.displayName %>
      </div>
    </div>

    <% if (typeof editUnavailable !== 'undefined' && editUnavailable) { %>
      <div class="edit-toolbar edit-toolbar--unavailable" id="edit-toolbar">
        <span class="edit-unavailable-msg">Editing temporarily unavailable — GitHub API rate limit reached.<% if (typeof rateLimitReset !== 'undefined' && rateLimitReset) { %> Expected to resume at <strong><%= new Date(rateLimitReset).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) %></strong>.<% } else { %> Please try again shortly.<% } %></span>
      </div>
    <% } else if (typeof editRole !== 'undefined' && editRole) { %>
      <div class="edit-toolbar" id="edit-toolbar">
        <button class="edit-btn" id="btn-suggest-edit">Suggest Edits</button>
        <% if (editRole === 'admin' || editRole === 'manuscript-owner') { %>
          <button class="edit-btn edit-btn--primary" id="btn-direct-edit">Direct Edit</button>
        <% } %>
        <%
          const sugCount = pendingSuggestions ? pendingSuggestions.length : 0;
          const comCount = pendingComments ? pendingComments.length : 0;
          const totalAnnotations = sugCount + comCount;
        %>
        <% if (totalAnnotations > 0) { %>
          <button class="edit-btn edit-btn--review" id="btn-review">
            Review <%= sugCount > 0 ? sugCount + ' suggestion' + (sugCount === 1 ? '' : 's') : '' %><%= (sugCount > 0 && comCount > 0) ? ', ' : '' %><%= comCount > 0 ? comCount + ' comment' + (comCount === 1 ? '' : 's') : '' %>
          </button>
        <% } %>
      </div>
    <% } %>

    <div class="reading-content" id="reading-content">
      <div class="session-content">
        <%- sessionHtml %>
      </div>

      <div class="session-nav">
        <% if (prevSession) { %>
          <a href="<%= content.sessionUrl(series, subseries, book, prevSession) %>" class="session-nav-link session-nav-prev">
            <span class="session-nav-dir">&larr; Previous</span>
            <span class="session-nav-name"><%= prevSession.displayName %></span>
          </a>
        <% } else { %>
          <div class="session-nav-link session-nav-placeholder"></div>
        <% } %>
        <% if (nextSession) { %>
          <a href="<%= content.sessionUrl(series, subseries, book, nextSession) %>" class="session-nav-link session-nav-next">
            <span class="session-nav-dir">Next &rarr;</span>
            <span class="session-nav-name"><%= nextSession.displayName %></span>
          </a>
        <% } else { %>
          <div class="session-nav-link session-nav-placeholder"></div>
        <% } %>
      </div>
    </div>

    <% if (typeof editRole !== 'undefined' && editRole) { %>
    <!-- Editor container (hidden until edit mode) -->
    <div class="editor-container" id="editor-container" style="display:none">
      <div class="editor-nav">
        <a href="<%= content.bookUrl(series, subseries, book) %>" class="editor-nav-link">&larr; <%= book.title %></a>
        <span class="editor-nav-sep">/</span>
        <span class="editor-nav-current"><%= session.title || session.displayName %></span>
      </div>
      <div class="editor-toolbar" id="editor-toolbar-bar">
        <div class="editor-toolbar-left">
          <span class="editor-mode-label" id="editor-mode-label">Suggesting Edits</span>
          <span class="editor-save-status" id="editor-save-status"></span>
          <div class="editor-toolbar-sep"></div>
          <div class="editor-search-group">
            <input type="text" class="editor-search-input" id="editor-search-input" placeholder="Find..." title="Search text (Enter = next, Shift+Enter = previous)">
            <button class="edit-btn edit-btn--tool" id="btn-search-prev" title="Previous match">&#9650;</button>
            <button class="edit-btn edit-btn--tool" id="btn-search-next" title="Next match">&#9660;</button>
            <button class="edit-btn edit-btn--tool" id="btn-search-clear" title="Clear search">&#10005;</button>
            <span class="editor-search-count" id="editor-search-count"></span>
          </div>
        </div>
        <div class="editor-presence" id="editor-presence"></div>
        <div class="editor-history-toggle">
          <button class="edit-btn edit-btn--tool editor-history-btn active" id="btn-margin-active" title="Active suggestions">Active</button>
          <button class="edit-btn edit-btn--tool editor-history-btn" id="btn-margin-history" title="Resolved history">History</button>
        </div>
        <div class="editor-toolbar-right">
          <label class="editor-toggle" title="Show line numbers">
            <input type="checkbox" id="chk-line-numbers" checked>
            <span>Lines</span>
          </label>
          <button class="edit-btn edit-btn--source" id="btn-view-source" title="Toggle raw markdown view">&lt;/&gt; Source</button>
          <div class="editor-toolbar-sep"></div>
          <button class="edit-btn edit-btn--tool" id="btn-prev-card" title="Previous suggestion or comment">&#9664; Prev Edit</button>
          <button class="edit-btn edit-btn--tool" id="btn-next-card" title="Next suggestion or comment">Next Edit &#9654;</button>
          <button class="edit-btn edit-btn--primary" id="btn-editor-done">Done</button>
        </div>
      </div>
      <div class="direct-edit-lock-banner" id="direct-edit-lock-banner" style="display:none"></div>
      <div class="editor-stale-banner" id="editor-stale-banner" style="display:none">
        <span class="stale-banner-icon">&#9888;</span>
        <span class="stale-banner-text" id="stale-banner-text"></span>
        <button class="stale-banner-btn" id="stale-banner-reload">Reload latest version</button>
        <button class="stale-banner-dismiss" id="stale-banner-dismiss" title="Dismiss">&times;</button>
      </div>
      <div class="editor-body">
        <div id="codemirror-host"></div>
        <div class="editor-refresh-overlay" id="editor-refresh-overlay" style="display:none">
          <span class="margin-card-spinner"></span>
          <span>Refreshing from GitHub...</span>
        </div>
        <div class="suggestion-margin" id="suggestion-margin">
          <div class="margin-empty">No changes yet</div>
        </div>
      </div>
      <!-- Floating comment popup (appears near selected text) -->
      <div class="comment-popup" id="comment-popup" style="display:none">
        <textarea class="comment-popup-input" id="comment-popup-input" placeholder="Add a comment..." rows="3"></textarea>
        <div class="comment-popup-actions">
          <button class="edit-btn" id="comment-popup-cancel">Cancel</button>
          <button class="edit-btn edit-btn--primary" id="comment-popup-submit">Comment</button>
        </div>
      </div>
      <!-- Toast notifications -->
      <div class="editor-toast" id="editor-toast" style="display:none"></div>
      <!-- Commit message modal -->
      <div class="editor-modal-overlay" id="commit-modal" style="display:none">
        <div class="editor-modal">
          <div class="editor-modal-header">
            <h3>Commit Changes</h3>
          </div>
          <div class="editor-modal-body">
            <label for="commit-message" class="editor-modal-label">Describe your changes (optional)</label>
            <textarea id="commit-message" class="editor-modal-textarea" rows="3" placeholder="e.g. Fixed grammar in introduction paragraph"></textarea>
          </div>
          <div class="editor-modal-footer">
            <button class="edit-btn" id="commit-cancel">Cancel</button>
            <button class="edit-btn edit-btn--primary" id="commit-confirm">Commit</button>
          </div>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Full-page loading overlay (shown during reload after exiting editor) -->
    <div class="page-reload-overlay" id="page-reload-overlay" style="display:none">
      <span class="margin-card-spinner" style="width:20px;height:20px"></span>
      <span>Loading latest content...</span>
    </div>

  </main>

<% if (typeof editRole !== 'undefined' && editRole) { %>
    <script>
      window.__EDITOR_DATA = JSON.parse('<%- JSON.stringify({
        rawContent: rawContent,
        contentSha: contentSha,
        editRole: editRole,
        sessionFilePath: sessionFilePath,
        bookRepoPath: bookRepoPath,
        pendingSuggestions: pendingSuggestions || [],
        pendingComments: pendingComments || [],
        pendingReplies: pendingReplies || [],
        canReview: canReview || false,
        user: user ? { email: user.email, displayName: user.displayName, photoURL: user.photoURL } : null,
      }).replace(/\\/g, "\\\\").replace(/\n/g, "\\n").replace(/\r/g, "\\r").replace(/'/g, "\\'").replace(/</g, "\\u003c") %>');
    </script>
    <script type="module" src="/static/js/editor.js?v=4"></script>
<% } %>

<%- include('partials/footer') %>
